{
  "name": "teru-victoria",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "npm run start:victoria",
    "start:victoria": "node scripts/set-brand.mjs victoria && ng serve",
    "start:teru": "node scripts/set-brand.mjs teru && ng serve",
    "build": "npm run build:victoria",
    "build:victoria": "node scripts/set-brand.mjs victoria && ng build --output-path dist/victoria",
    "build:teru": "node scripts/set-brand.mjs teru && ng build --output-path dist/teru",
    "build:all": "npm run build:victoria && npm run build:teru",
    "config:victoria": "node scripts/set-brand.mjs victoria",
    "config:teru": "node scripts/set-brand.mjs teru",
    "gen:images": "node scripts/gen-placeholders.mjs",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.6.2",
  "dependencies": {
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/router": "^21.0.0",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.0.5",
    "@angular/cli": "^21.0.5",
    "@angular/compiler-cli": "^21.0.0",
    "@types/leaflet": "^1.9.21",
    "@types/leaflet.markercluster": "^1.5.6",
    "jsdom": "^27.1.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
